# ============================================================
# MAVEN / JAVA
# ============================================================
HELP.md
target/
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ============================================================
# FRONTEND — Node / Vite
# ============================================================

# Never commit node_modules — restored by `npm install`
frontend/node_modules/

# Vite production build output — regenerated by `mvn install`
frontend/dist/

frontend/package-lock.json

# Vite cache
frontend/.vite/

# ============================================================
# ENVIRONMENT & SECRETS — Never commit these
# ============================================================

# Local environment files (may contain API keys)
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Spring Boot secrets (Gemini API key lives here)
src/main/resources/application-local.properties
src/main/resources/application-secret.properties

# ============================================================
# IDE — Spring Tool Suite (STS)
# ============================================================
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# ============================================================
# IDE — IntelliJ IDEA
# ============================================================
.idea/
*.iws
*.iml
*.ipr

# ============================================================
# IDE — VS Code
# ============================================================
.vscode/

# ============================================================
# IDE — NetBeans
# ============================================================
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# ============================================================
# OS FILES
# ============================================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ============================================================
# LOGS
# ============================================================
*.log
logs/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# ============================================================
# MISC
# ============================================================

# Maven downloaded Node/NPM binaries (auto-downloaded per build)
target/node/

# Package manager lock files — keep package-lock.json, ignore others
frontend/yarn.lock
frontend/pnpm-lock.yaml
